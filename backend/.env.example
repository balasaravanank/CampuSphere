# CampuSphere Backend Environment Variables
# Copy this to .env and fill in the values

# === APP ===
DEBUG=true
APP_NAME=CampuSphere
APP_VERSION=1.0.0

# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://campusphere:campusphere@localhost:5432/campusphere

# === REDIS ===
REDIS_URL=redis://localhost:6379/0

# === JWT ===
JWT_SECRET_KEY=your-64-char-random-string-here-change-in-production-please-now
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === GOOGLE OAUTH ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=saveetha.ac.in

# === MINIO ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=campusphere-uploads

# === CORS ===
CORS_ORIGINS=["http://localhost:5173"]

# === SECURITY ===
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=30
